DJANGO_DEBUG=1
DJANGO_SECRET_KEY=secret_key
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

STATBALLER_DB_NAME=dbname
STATBALLER_DB_USER=dbuser
STATBALLER_DB_PASSWORD=dbpass
STATBALLER_DB_HOST=127.0.0.1
STATBALLER_DB_PORT=5432

CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
# CELERY_WORKER_PREFETCH_MULTIPLIER=1
# CELERY_WORKER_MAX_TASKS_PER_CHILD=1
# CELERY_WORKER_MAX_MEMORY_PER_CHILD=900000
STATBALLER_REGRESSION_FIT_RATE=30/min
STATBALLER_DAILY_REFRESH_ENABLED=0
STATBALLER_DAILY_REFRESH_START_HOUR=1
STATBALLER_DAILY_REFRESH_END_HOUR=7
STATBALLER_DAILY_REFRESH_TIME_ZONE=Europe/London
STATBALLER_DAILY_REFRESH_MIN_LEAGUE_DELAY_SECONDS=600
STATBALLER_DAILY_REFRESH_MAX_LEAGUE_DELAY_SECONDS=1500
STATBALLER_SOFASCORE_REQUEST_DELAY_SECONDS=4.0
STATBALLER_SOFASCORE_DAILY_REQUEST_CAP=1000
STATBALLER_SOFASCORE_PROXY_URL=

# Production-like settings keep disabled locally unless serving HTTPS
DJANGO_SECURE_SSL_REDIRECT=0
DJANGO_SESSION_COOKIE_SECURE=0
DJANGO_CSRF_COOKIE_SECURE=0
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=0
DJANGO_SECURE_HSTS_PRELOAD=0
DJANGO_TRUST_X_FORWARDED_PROTO=0
